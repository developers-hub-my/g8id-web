---
const states = [
  { name: 'Pending', color: 'text-amber-400', bgColor: 'bg-amber-400/10 border-amber-400/20', description: 'Identity created, awaiting approval' },
  { name: 'Active', color: 'text-green-400', bgColor: 'bg-green-400/10 border-green-400/20', description: 'Fully provisioned and operational' },
  { name: 'Suspended', color: 'text-orange-400', bgColor: 'bg-orange-400/10 border-orange-400/20', description: 'Temporarily disabled (leave, investigation)' },
  { name: 'Terminated', color: 'text-red-400', bgColor: 'bg-red-400/10 border-red-400/20', description: 'Offboarded, all access revoked' },
  { name: 'Archived', color: 'text-slate-400', bgColor: 'bg-slate-400/10 border-slate-400/20', description: 'Historical record preserved for audit' },
];

const events = [
  { name: 'Joined', description: 'New hire onboarding', from: 'Pending', to: 'Active' },
  { name: 'Moved', description: 'Department transfer', from: 'Active', to: 'Active' },
  { name: 'Suspended', description: 'Leave of absence', from: 'Active', to: 'Suspended' },
  { name: 'Returned', description: 'Rehire / return', from: 'Suspended', to: 'Active' },
  { name: 'Left', description: 'Resignation / termination', from: 'Active', to: 'Terminated' },
];

const roles = [
  { name: 'Superadmin', permissions: 'Full system access' },
  { name: 'Admin', permissions: 'Identity & connector management' },
  { name: 'Approver', permissions: 'Approval decisions' },
  { name: 'Helpdesk', permissions: 'Password resets, basic ops' },
  { name: 'Human Resource', permissions: 'JML operations, identity creation' },
  { name: 'Manager', permissions: 'Team view, recertification' },
  { name: 'User', permissions: 'Self-service portal access' },
];
---

<section id="lifecycle" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Identity Lifecycle</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Every Identity Has a Story
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        G8ID tracks the complete lifecycle of every identity — from first day to last, with every state change logged and controlled.
      </p>
    </div>

    <div class="mt-16 grid gap-10 lg:grid-cols-2">
      <!-- State Machine -->
      <div>
        <h3 class="mb-6 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Identity States</h3>

        <!-- Visual flow -->
        <div class="flex flex-col gap-3">
          {states.map((state, i) => (
            <div class="flex items-center gap-4">
              <div class={`flex h-10 shrink-0 items-center gap-3 rounded-lg border px-4 ${state.bgColor}`}>
                <span class={`font-display text-sm font-bold ${state.color}`}>{state.name}</span>
              </div>
              <span class="text-xs text-slate-500">{state.description}</span>
            </div>
          ))}
        </div>

        <!-- Lifecycle events -->
        <h3 class="mb-4 mt-10 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Lifecycle Events</h3>
        <div class="space-y-2">
          {events.map((event) => (
            <div class="flex items-center gap-3 rounded-lg border border-white/5 bg-navy-900/30 px-4 py-3">
              <span class="font-display text-sm font-bold text-cyan-400 w-24 shrink-0">{event.name}</span>
              <span class="text-xs text-slate-400 flex-1">{event.description}</span>
              <span class="text-xs text-slate-500 shrink-0">{event.from} &rarr; {event.to}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- RBAC -->
      <div>
        <h3 class="mb-6 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Built-in Roles</h3>
        <p class="mb-6 text-sm text-slate-400">
          Seven pre-built roles with 40+ fine-grained permissions across identity management, approvals, connectors, audit, and the self-service portal.
        </p>
        <div class="space-y-3">
          {roles.map((role) => (
            <div class="flex items-center gap-4 rounded-lg border border-white/5 bg-navy-900/30 px-4 py-3">
              <span class="font-display text-sm font-bold text-white w-32 shrink-0">{role.name}</span>
              <span class="text-xs text-slate-400">{role.permissions}</span>
            </div>
          ))}
        </div>

        <!-- Role to Group mapping callout -->
        <div class="mt-6 rounded-lg border border-cyan-400/10 bg-cyan-400/5 p-4">
          <p class="text-xs text-cyan-400/80">
            <span class="font-display font-bold">Role-to-Group Sync:</span> G8ID roles map directly to AD/LDAP security groups. Assign a role in G8ID, the user is automatically added to the corresponding directory group.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
