---
const capabilities = [
  {
    title: 'Approval Workflows',
    description: 'Multi-level, policy-driven approval chains with auto-expiry. No access without explicit sign-off.',
  },
  {
    title: 'Joiner-Mover-Leaver',
    description: 'HR events trigger automated identity lifecycle. Onboard, transfer, suspend, or offboard — all through one pipeline.',
  },
  {
    title: 'Immutable Audit Log',
    description: 'Every action recorded with actor, before/after state, and timestamp. Cannot be edited or deleted — ever.',
  },
  {
    title: 'Recertification Campaigns',
    description: 'Periodic access reviews where managers certify or revoke role assignments. Uncertified roles are auto-revoked.',
  },
];
---

<section id="features" class="relative py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <div>
        <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">The Solution</span>
        <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          One Gate Between Your Business and Your Directories
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-slate-400">
          G8ID sits between your business processes and your identity stores. Every provision, update, and offboard passes through one controlled pipeline. No one touches Active Directory or LDAP directly anymore.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          {['Request', 'Approve', 'Execute', 'Audit'].map((step, i) => (
            <div class="flex items-center gap-3">
              <span class="rounded-lg border border-cyan-400/20 bg-cyan-400/5 px-4 py-2 font-display text-sm font-bold text-cyan-400">
                {step}
              </span>
              {i < 3 && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Product screenshot -->
      <div class="overflow-hidden rounded-xl border border-white/10 shadow-2xl shadow-cyan-400/5">
        <img
          src="/images/identity-overview.png"
          alt="G8ID identity profile — employee details, directory mapping, and group memberships"
          class="w-full"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Key capabilities -->
    <div class="mt-20 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {capabilities.map((cap) => (
        <div class="rounded-xl border border-white/5 bg-navy-900/50 p-6 transition-colors hover:border-cyan-400/20">
          <h3 class="font-display text-lg font-bold text-white">{cap.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{cap.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
