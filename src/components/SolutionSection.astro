---
---

<section class="relative py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid items-center gap-16 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
          G8ID Is the <span class="text-cyan-400">Gate</span>
        </h2>
        <p class="mt-6 text-lg leading-relaxed text-slate-400">
          G8ID is an Identity Data Management system that sits between your business processes and your identity stores. Every identity operation — provision, update, disable, offboard — passes through G8ID's controlled pipeline.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-slate-400">
          No one touches Active Directory, LDAP, or Keycloak directly anymore. Every action follows one path:
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          {['Request', 'Approval', 'Execute', 'Audit'].map((step, i) => (
            <div class="flex items-center gap-3">
              <span class="rounded-lg border border-cyan-400/20 bg-cyan-400/5 px-4 py-2 font-display text-sm font-bold text-cyan-400">
                {step}
              </span>
              {i < 3 && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              )}
            </div>
          ))}
        </div>
      </div>

      <!-- Flow diagram -->
      <div class="flex items-center justify-center">
        <svg viewBox="0 0 360 300" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-sm">
          <!-- Source nodes -->
          <rect x="20" y="10" width="96" height="36" rx="6" fill="#151D38" stroke="#253058" stroke-width="1"/>
          <text x="68" y="32" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="monospace">HR System</text>

          <rect x="132" y="10" width="96" height="36" rx="6" fill="#151D38" stroke="#253058" stroke-width="1"/>
          <text x="180" y="32" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="monospace">Helpdesk</text>

          <rect x="244" y="10" width="96" height="36" rx="6" fill="#151D38" stroke="#253058" stroke-width="1"/>
          <text x="292" y="32" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="monospace">Self-Service</text>

          <!-- Arrows down to gate -->
          <path d="M68 46 L180 100" stroke="#00D4FF" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)"/>
          <path d="M180 46 L180 100" stroke="#00D4FF" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)"/>
          <path d="M292 46 L180 100" stroke="#00D4FF" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)"/>

          <!-- G8ID Gate -->
          <rect x="120" y="104" width="120" height="52" rx="8" fill="#00D4FF" fill-opacity="0.08" stroke="#00D4FF" stroke-width="2"/>
          <text x="180" y="128" text-anchor="middle" fill="#00D4FF" font-size="16" font-weight="bold" font-family="monospace">G8ID</text>
          <text x="180" y="146" text-anchor="middle" fill="#00D4FF" font-size="9" font-family="monospace" opacity="0.6">GATE</text>

          <!-- Arrows down to targets -->
          <path d="M155 156 L80 220" stroke="#00D4FF" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)"/>
          <path d="M180 156 L180 220" stroke="#00D4FF" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)"/>
          <path d="M205 156 L280 220" stroke="#00D4FF" stroke-width="1" opacity="0.4" marker-end="url(#arrowhead)"/>

          <!-- Target nodes -->
          <rect x="30" y="224" width="100" height="40" rx="6" fill="#151D38" stroke="#00D4FF" stroke-width="0.5" opacity="0.6"/>
          <text x="80" y="248" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="monospace">Active Directory</text>

          <rect x="130" y="224" width="100" height="40" rx="6" fill="#151D38" stroke="#00D4FF" stroke-width="0.5" opacity="0.6"/>
          <text x="180" y="248" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="monospace">LDAP</text>

          <rect x="230" y="224" width="100" height="40" rx="6" fill="#151D38" stroke="#00D4FF" stroke-width="0.5" opacity="0.6"/>
          <text x="280" y="248" text-anchor="middle" fill="#94A3B8" font-size="10" font-family="monospace">Keycloak</text>

          <defs>
            <marker id="arrowhead" markerWidth="8" markerHeight="6" refX="8" refY="3" orient="auto">
              <path d="M0 0 L8 3 L0 6" fill="none" stroke="#00D4FF" stroke-width="1" opacity="0.6"/>
            </marker>
          </defs>
        </svg>
      </div>
    </div>
  </div>
</section>
