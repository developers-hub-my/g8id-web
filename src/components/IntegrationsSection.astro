---
const connectors = [
  { name: 'Active Directory', type: 'Identity Connector' },
  { name: 'LDAP', type: 'Identity Connector' },
];

const ssoProviders = [
  { name: 'Keycloak', type: 'SSO Provider' },
  { name: 'Azure AD', type: 'SSO Provider' },
  { name: 'Okta', type: 'SSO Provider' },
  { name: 'Generic OIDC', type: 'SSO Provider' },
];

const extensibility = [
  {
    title: 'Custom Connectors',
    description: 'Implement the IdentityConnectorContract to add support for any directory or identity store.',
  },
  {
    title: 'Custom SSO Providers',
    description: 'Implement the SsoProviderContract to integrate any SSO platform for session revocation.',
  },
  {
    title: 'Attribute Transformers',
    description: 'Custom data transformers to map, format, and validate attributes during sync.',
  },
  {
    title: 'Webhook Events',
    description: 'Event-driven notifications to SIEM, ITSM, HR systems, and any downstream platform.',
  },
];
---

<section id="integrations" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Integrations</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Works With Your Stack
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        G8ID connects to your identity stores and SSO providers out of the box. Need something else? The contract-based architecture makes it extensible.
      </p>
    </div>

    <!-- Connectors & SSO Providers -->
    <div class="mt-16 grid gap-8 lg:grid-cols-2">
      <!-- Identity Connectors -->
      <div class="rounded-xl border border-white/5 bg-navy-900/50 p-8">
        <h3 class="mb-6 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Identity Connectors</h3>
        <div class="grid gap-4">
          {connectors.map((c) => (
            <div class="flex items-center gap-4 rounded-lg border border-white/5 bg-navy-950/50 p-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
                </svg>
              </div>
              <div>
                <p class="font-display text-sm font-bold text-white">{c.name}</p>
                <p class="text-xs text-slate-500">{c.type}</p>
              </div>
              <span class="ml-auto rounded-full border border-green-400/20 bg-green-400/5 px-2.5 py-0.5 text-xs text-green-400">Built-in</span>
            </div>
          ))}
        </div>
      </div>

      <!-- SSO Providers -->
      <div class="rounded-xl border border-white/5 bg-navy-900/50 p-8">
        <h3 class="mb-6 font-display text-sm font-bold uppercase tracking-widest text-slate-500">SSO Providers</h3>
        <div class="grid gap-4">
          {ssoProviders.map((s) => (
            <div class="flex items-center gap-4 rounded-lg border border-white/5 bg-navy-950/50 p-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
                </svg>
              </div>
              <div>
                <p class="font-display text-sm font-bold text-white">{s.name}</p>
                <p class="text-xs text-slate-500">{s.type}</p>
              </div>
              <span class="ml-auto rounded-full border border-green-400/20 bg-green-400/5 px-2.5 py-0.5 text-xs text-green-400">Built-in</span>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Extensibility -->
    <div class="mt-10">
      <h3 class="mb-6 text-center font-display text-sm font-bold uppercase tracking-widest text-slate-500">Extensibility</h3>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {extensibility.map((ext) => (
          <div class="rounded-xl border border-white/5 bg-navy-900/30 p-5 transition-colors hover:border-cyan-400/20">
            <h4 class="font-display text-sm font-bold text-white">{ext.title}</h4>
            <p class="mt-2 text-xs leading-relaxed text-slate-400">{ext.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
