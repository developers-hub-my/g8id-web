---
const specs = [
  { label: 'Deployment', value: 'Linux (Debian/Ubuntu/RHEL), Docker, Kubernetes' },
  { label: 'Database', value: 'MySQL / MariaDB' },
  { label: 'Queue', value: 'Redis + Laravel Horizon' },
  { label: 'Air-Gap Updates', value: 'Offline package bundles — no internet required' },
  { label: 'API', value: 'REST API for JML triggers and external integrations' },
  { label: 'High Availability', value: 'Active-passive supported; DB clustering via standard MySQL HA' },
  { label: 'Minimum Specs', value: '4 vCPU, 8 GB RAM, 50 GB storage (up to 10,000 identities)' },
];
---

<section id="technical" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">For Your IT Team</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Technical Overview
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Everything your architects and security team need to evaluate G8ID.
      </p>
    </div>

    <div class="mx-auto mt-16 max-w-3xl rounded-xl border border-white/5 bg-navy-900/50 overflow-hidden">
      {specs.map((spec, i) => (
        <div class:list={['flex flex-col gap-1 p-5 sm:flex-row sm:items-center sm:gap-6', i > 0 && 'border-t border-white/5']}>
          <span class="w-44 shrink-0 font-display text-sm font-bold text-cyan-400">{spec.label}</span>
          <span class="text-sm text-slate-400">{spec.value}</span>
        </div>
      ))}
    </div>
  </div>
</section>
