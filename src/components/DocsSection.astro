---
---

<section id="docs" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Documentation</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Resources & Documentation
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Technical documentation, deployment guides, and API references available upon demo request.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-3">
      <div class="rounded-xl border border-white/5 bg-navy-900/50 p-6 text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">Admin Guide</h3>
        <p class="mt-2 text-sm text-slate-400">Setup, configuration, connector management, and day-to-day operations.</p>
      </div>

      <div class="rounded-xl border border-white/5 bg-navy-900/50 p-6 text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">API Reference</h3>
        <p class="mt-2 text-sm text-slate-400">REST API documentation for JML triggers, identity operations, and external integrations.</p>
      </div>

      <div class="rounded-xl border border-white/5 bg-navy-900/50 p-6 text-center">
        <div class="mx-auto mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </div>
        <h3 class="font-display text-lg font-bold text-white">Deployment Guide</h3>
        <p class="mt-2 text-sm text-slate-400">Installation, Docker setup, air-gap deployment, and high-availability configuration.</p>
      </div>
    </div>

    <div class="mt-8 text-center">
      <a
        href="mailto:hello@devhub.my?subject=G8ID%20Documentation%20Request"
        class="inline-flex items-center gap-2 text-sm font-medium text-cyan-400 transition-colors hover:text-cyan-300"
      >
        Request full documentation access
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
