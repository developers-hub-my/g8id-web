---
const steps = [
  {
    number: '01',
    title: 'Revoke SSO Sessions',
    description: 'Immediately terminate all active sessions across Keycloak, Azure AD, Okta, or any OIDC provider.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />`,
  },
  {
    number: '02',
    title: 'Disable Directory Accounts',
    description: 'Disable accounts across all connected AD and LDAP directories simultaneously.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />`,
  },
  {
    number: '03',
    title: 'Remove Security Groups',
    description: 'Strip all security group memberships. No lingering access to shared resources.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
  {
    number: '04',
    title: 'Remove Distribution Lists',
    description: 'Remove from all email distribution lists. No more company-wide emails reaching ex-staff.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    number: '05',
    title: 'Transfer Mailbox',
    description: 'Transition mailbox ownership to a designated successor or manager.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />`,
  },
  {
    number: '06',
    title: 'Archive Home Directory',
    description: 'Preserve user files and data for compliance retention before removal.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />`,
  },
  {
    number: '07',
    title: 'Revoke VPN Certificates',
    description: 'Revoke all VPN and network access certificates. No remote access post-departure.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />`,
  },
  {
    number: '08',
    title: 'Notify Downstream Systems',
    description: 'Webhook notifications to ITSM, HR systems, SIEM, and any integrated platforms.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />`,
  },
  {
    number: '09',
    title: 'Archive Identity Record',
    description: 'Move identity to archived state. Full history preserved for audit and compliance.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
  },
];
---

<section id="offboarding" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Offboarding Pipeline</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        9-Step Automated Offboarding
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        When someone leaves, G8ID executes a cascading pipeline. Each step runs independently — a failure in one doesn't halt the rest. No orphaned accounts. No lingering access.
      </p>
    </div>

    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {steps.map((step) => (
        <div class="group relative rounded-xl border border-white/5 bg-navy-900/50 p-5 transition-colors hover:border-cyan-400/20">
          <div class="mb-3 flex items-center gap-3">
            <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-cyan-400/30 bg-navy-950 font-display text-xs font-bold text-cyan-400">
              {step.number}
            </span>
            <div class="flex h-8 w-8 shrink-0 items-center justify-center text-cyan-400/60">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={step.icon} />
              </svg>
            </div>
          </div>
          <h3 class="font-display text-sm font-bold text-white">{step.title}</h3>
          <p class="mt-1.5 text-xs leading-relaxed text-slate-400">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Failure isolation callout -->
    <div class="mt-8 rounded-xl border border-amber-500/20 bg-amber-500/5 p-6 text-center">
      <p class="text-sm text-amber-400/90">
        <span class="font-display font-bold">Failure Isolation:</span> Each step is independently executed and logged. If step 5 fails, steps 6–9 still run. Failed steps trigger alerts for manual intervention — nothing slips through.
      </p>
    </div>
  </div>
</section>
