---
const problems = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /><line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.5"/></svg>`,
    title: 'Orphaned Accounts',
    description: 'Ex-employees still active in AD months after leaving. Every orphaned account is an open door.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 11V7a4 4 0 118 0m-4 8v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2z" /></svg>`,
    title: 'Privilege Creep',
    description: 'Users accumulate access across transfers and role changes. Permissions are never revoked — only added.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'No Audit Trail',
    description: '"Who gave John access to Finance?" — nobody knows. When auditors ask, you scramble for answers.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`,
    title: 'Manual AD Errors',
    description: 'Wrong OU, typos in group names, stale passwords, inconsistent naming. Human error is the norm.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>`,
    title: 'Compliance Failures',
    description: 'SOC2, ISO 27001, PDPA reviews failing because access reviews are manual, incomplete, or nonexistent.',
  },
];
---

<section class="relative py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        The Mess You're Living With
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Without a gate between your business and your identity stores, every one of these is an active liability.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {problems.map((problem) => (
        <div class="group rounded-xl border border-red-500/10 bg-red-500/[0.03] p-6 transition-colors hover:border-red-500/20">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-red-500/10 text-red-400">
            <Fragment set:html={problem.icon} />
          </div>
          <h3 class="font-display text-lg font-bold text-white">{problem.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{problem.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
