---
const modules = [
  {
    id: 'core',
    name: 'Identity & Lifecycle',
    description: 'The central identity registry with a full state machine — Pending, Active, Suspended, Terminated, Archived. HR events trigger automated JML (Joiner-Mover-Leaver) workflows. Zero-code dynamic attributes, role-to-group mapping, and OU structure management.',
    features: [
      'Identity lifecycle state machine with automated transitions',
      'JML automation: join, move, leave, return, suspend',
      'Zero-code dynamic attributes with 10+ types and sensitivity levels',
      '5 pre-built roles with 40+ fine-grained permissions',
      'Role-to-AD/LDAP group auto-sync',
      'Scheduled reinstatement for time-bounded suspension',
    ],
    screenshot: '/images/roles.png',
    screenshotAlt: 'G8ID Roles — role management with directory group mappings',
  },
  {
    id: 'connect',
    name: 'Connectors & SSO',
    description: 'The bridge to your identity stores. AD and LDAP connectors with pluggable SSO session revocation for Keycloak, Azure AD, Okta, and any OIDC provider. Browse and manage directory groups from one control plane.',
    features: [
      'Active Directory and LDAP connectors with OU auto-creation',
      'SSO providers: Keycloak, Azure AD, Okta, Generic OIDC',
      'Directory group browsing, creation, and membership management',
      'Daily drift detection and reconciliation alerts',
      'Bulk import/export and connection health checks',
    ],
    screenshot: '/images/connectors.png',
    screenshotAlt: 'G8ID Connectors — LDAP connector configuration with SSL/TLS settings',
  },
  {
    id: 'flow',
    name: 'Approvals & Workflows',
    description: 'Policy-driven approval chains with multi-level sign-off, auto-expiry, and delegation. Recertification campaigns for periodic access reviews. 9-step automated offboarding cascade that runs even if individual steps fail.',
    features: [
      'Multi-level approvals with configurable levels per operation',
      'Auto-expiry with configurable timeout (default: 72h)',
      'Recertification campaigns with auto-revocation',
      '9-step automated offboarding cascade pipeline',
      'Time-bounded access with scheduled revocation',
    ],
    screenshot: '/images/approval-policies.png',
    screenshotAlt: 'G8ID Approval Policies — configurable approval levels and expiry per operation',
  },
  {
    id: 'audit',
    name: 'Audit & Compliance',
    description: 'Tamper-proof audit logs that can never be edited or deleted. Before/after state capture, approval references, and actor tracking. Export evidence for SOC2, ISO 27001, and PDPA reviews.',
    features: [
      'Immutable event log — no edits, no deletes, ever',
      'Before/after state diffs for every change',
      'Searchable by identity, operation, status, and date range',
      'CSV and Excel export for audit evidence',
      'Compliance-ready: SOC2, ISO 27001, PDPA',
    ],
    screenshot: '/images/audit-log.png',
    screenshotAlt: 'G8ID Audit Log — immutable record of operations with actor and status',
  },
];
---

<section id="platform" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Platform</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        See It In Action
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Four modules that work together to give you complete control over your identity infrastructure.
      </p>
    </div>

    <div x-data="{ active: 'core' }" class="mt-16">
      <!-- Tab buttons -->
      <div class="flex flex-wrap justify-center gap-2">
        {modules.map((mod) => (
          <button
            @click={`active = '${mod.id}'`}
            :class={`active === '${mod.id}' ? 'border-cyan-400 bg-cyan-400/10 text-cyan-400' : 'border-white/10 text-slate-400 hover:border-white/20 hover:text-slate-300'`}
            class="rounded-lg border px-4 py-2.5 font-display text-sm font-bold transition-all"
          >
            {mod.name}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      {modules.map((mod) => (
        <div
          x-show={`active === '${mod.id}'`}
          x-cloak
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="mt-10 rounded-xl border border-white/5 bg-navy-900/50 p-8 lg:p-12"
        >
          <div class="grid items-start gap-10 lg:grid-cols-2">
            <!-- Screenshot -->
            <div class="overflow-hidden rounded-lg border border-white/10">
              <img
                src={mod.screenshot}
                alt={mod.screenshotAlt}
                class="w-full"
                loading="lazy"
              />
            </div>

            <!-- Content -->
            <div>
              <h3 class="font-display text-2xl font-bold text-white">{mod.name}</h3>
              <p class="mt-4 leading-relaxed text-slate-400">{mod.description}</p>

              <ul class="mt-6 space-y-3">
                {mod.features.map((feature) => (
                  <li class="flex items-start gap-3 text-sm text-slate-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-4 w-4 shrink-0 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
