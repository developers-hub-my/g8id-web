---
const modules = [
  {
    id: 'core',
    name: 'G8ID Core',
    tagline: 'Identity Registry & Lifecycle',
    description: 'The central identity registry. Manages the full identity lifecycle — from joiner provisioning to leaver offboarding. Tracks canonical identity records with a proper state machine, dynamic attributes, and role-to-group mapping.',
    features: ['Identity registry with state machine (Pending → Active → Suspended → Terminated → Archived)', 'JML automation: Joined, Moved, Left, Returned, Suspended events', 'Zero-code dynamic attributes with 10+ types and sensitivity levels', 'OU structure management with automatic path building', 'Role-to-AD/LDAP group auto-sync', '7 pre-built roles with 40+ fine-grained permissions', 'Scheduled reinstatement for time-bounded suspension'],
  },
  {
    id: 'connect',
    name: 'G8ID Connect',
    tagline: 'Connector & SSO Layer',
    description: 'The bridge to your identity stores and SSO providers. Connectors for AD and LDAP with pluggable SSO session revocation for Keycloak, Azure AD, Okta, and any OIDC provider. Contract-based architecture for extensibility.',
    features: ['Active Directory connector with OU auto-creation', 'LDAP connector for any compliant directory', 'SSO providers: Keycloak, Azure AD, Okta, Generic OIDC', 'Group browsing, creation, and membership management', 'Daily drift detection and reconciliation alerts', 'Bulk user import/export from directories', 'Connection health checks with error classification'],
  },
  {
    id: 'flow',
    name: 'G8ID Flow',
    tagline: 'Approval & Workflow Engine',
    description: 'Policy-driven approval chains with multi-level sign-off, auto-expiry, and delegation. Supports recertification campaigns for periodic access reviews. No access without explicit approval.',
    features: ['Multi-level approvals with configurable levels per operation', 'Auto-expiry with configurable timeout (default: 72h)', 'Approval delegation to alternate approvers', 'Recertification campaigns with auto-revocation', '9-step automated offboarding cascade pipeline', 'Time-bounded access with scheduled revocation', 'Context-aware rules by department, role, or operation type'],
  },
  {
    id: 'audit',
    name: 'G8ID Audit',
    tagline: 'Immutable Audit & Compliance',
    description: 'Tamper-proof audit logs that can never be edited or deleted. Before/after state capture, approval references, and actor tracking. Streamed exports for auditors.',
    features: ['Immutable event log — no edits, no deletes, ever', 'Before/after state diffs for every change', 'Directory sync audit with success/failure/skip metrics', 'Offboarding step-by-step logging with failure tracking', 'CSV and Excel export for audit evidence', 'Searchable by identity, operation, status, and date range', 'Compliance-ready: SOC2, ISO 27001, PDPA'],
  },
  {
    id: 'portal',
    name: 'G8ID Portal',
    tagline: 'Self-Service & Manager Portal',
    description: 'A web portal for end users and managers. Self-service profile updates, access requests, and password management. Managers get team visibility, approval inbox, and recertification workflows.',
    features: ['Self-service profile updates (no approval for self-service attributes)', 'Access request tracking with status visibility', 'Manager team view with subordinate search and filters', 'Recertification inbox for periodic access reviews', 'In-app notification bell with unread count', 'Token-based self-activation for new accounts', 'Password management across all connected directories'],
  },
];
---

<section id="modules" class="relative py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        The G8ID Platform
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Five modules that work together to give you complete control over your identity infrastructure.
      </p>
    </div>

    <div x-data="{ active: 'core' }" class="mt-16">
      <!-- Tab buttons -->
      <div class="flex flex-wrap justify-center gap-2">
        {modules.map((mod) => (
          <button
            @click={`active = '${mod.id}'`}
            :class={`active === '${mod.id}' ? 'border-cyan-400 bg-cyan-400/10 text-cyan-400' : 'border-white/10 text-slate-400 hover:border-white/20 hover:text-slate-300'`}
            class="rounded-lg border px-4 py-2.5 font-display text-sm font-bold transition-all"
          >
            {mod.name}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      {modules.map((mod) => (
        <div
          x-show={`active === '${mod.id}'`}
          x-cloak
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="mt-10 rounded-xl border border-white/5 bg-navy-900/50 p-8 lg:p-12"
        >
          <div class="grid gap-8 lg:grid-cols-2">
            <div>
              <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">{mod.tagline}</span>
              <h3 class="mt-2 font-display text-2xl font-bold text-white">{mod.name}</h3>
              <p class="mt-4 leading-relaxed text-slate-400">{mod.description}</p>
            </div>
            <div>
              <h4 class="mb-4 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Capabilities</h4>
              <ul class="space-y-3">
                {mod.features.map((feature) => (
                  <li class="flex items-center gap-3 text-sm text-slate-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
