---
const modules = [
  {
    id: 'core',
    name: 'G8ID Core',
    tagline: 'Identity Registry & Lifecycle',
    description: 'The central identity registry. Manages the full identity lifecycle — from joiner provisioning to leaver offboarding. Stores canonical identity records, role assignments, and attribute history.',
    features: ['Identity registry', 'Lifecycle state machine', 'JML automation', 'Role assignments', 'Attribute history'],
  },
  {
    id: 'connect',
    name: 'G8ID Connect',
    tagline: 'Connector Layer',
    description: 'The bridge to your identity stores. Connectors for Active Directory and LDAP — abstracted behind a contract so you can add new targets without touching core logic. Includes drift detection and reconciliation.',
    features: ['AD connector', 'LDAP connector', 'Contract-based architecture', 'Drift detection', 'Reconciliation engine'],
  },
  {
    id: 'flow',
    name: 'G8ID Flow',
    tagline: 'Approval Workflow Engine',
    description: 'Policy-driven approval chains. Multi-level approvals with auto-escalation, time-bounded access, and delegation rules. No access without sign-off.',
    features: ['Multi-level approvals', 'Auto-escalation', 'Time-bounded access', 'Delegation rules', 'Policy engine'],
  },
  {
    id: 'audit',
    name: 'G8ID Audit',
    tagline: 'Immutable Audit & Compliance',
    description: 'Tamper-proof audit logs for every identity operation. Pre-built compliance reports for SOC2, ISO 27001, and PDPA. Access review campaigns at the click of a button.',
    features: ['Immutable event log', 'Compliance reports', 'Access reviews', 'Export to SIEM', 'Forensic search'],
  },
  {
    id: 'portal',
    name: 'G8ID Portal',
    tagline: 'Self-Service & Manager Portal',
    description: 'A web portal for end users and managers. Self-service password resets, access requests, and approval dashboards. Reduces helpdesk tickets and empowers managers.',
    features: ['Self-service requests', 'Manager dashboard', 'Approval inbox', 'Password reset', 'Access catalogue'],
  },
];
---

<section id="modules" class="relative py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        The G8ID Platform
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Five modules that work together to give you complete control over your identity infrastructure.
      </p>
    </div>

    <div x-data="{ active: 'core' }" class="mt-16">
      <!-- Tab buttons -->
      <div class="flex flex-wrap justify-center gap-2">
        {modules.map((mod) => (
          <button
            @click={`active = '${mod.id}'`}
            :class={`active === '${mod.id}' ? 'border-cyan-400 bg-cyan-400/10 text-cyan-400' : 'border-white/10 text-slate-400 hover:border-white/20 hover:text-slate-300'`}
            class="rounded-lg border px-4 py-2.5 font-display text-sm font-bold transition-all"
          >
            {mod.name}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      {modules.map((mod) => (
        <div
          x-show={`active === '${mod.id}'`}
          x-cloak
          x-transition:enter="transition ease-out duration-200"
          x-transition:enter-start="opacity-0 translate-y-2"
          x-transition:enter-end="opacity-100 translate-y-0"
          class="mt-10 rounded-xl border border-white/5 bg-navy-900/50 p-8 lg:p-12"
        >
          <div class="grid gap-8 lg:grid-cols-2">
            <div>
              <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">{mod.tagline}</span>
              <h3 class="mt-2 font-display text-2xl font-bold text-white">{mod.name}</h3>
              <p class="mt-4 leading-relaxed text-slate-400">{mod.description}</p>
            </div>
            <div>
              <h4 class="mb-4 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Capabilities</h4>
              <ul class="space-y-3">
                {mod.features.map((feature) => (
                  <li class="flex items-center gap-3 text-sm text-slate-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
