---
const pillars = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />`,
    title: 'Immutable Audit Trail',
    description: 'Every identity operation is recorded with actor, subject, operation, before/after state, approval reference, and timestamp. Logs cannot be edited or deleted — ever.',
    tags: ['SOC2', 'ISO 27001', 'PDPA'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
    title: 'Recertification Campaigns',
    description: 'Periodic access review campaigns where managers certify or revoke role assignments. Uncertified roles are automatically revoked. Auditors love this.',
    tags: ['Access Review', 'Auto-Revoke'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />`,
    title: 'Drift Detection',
    description: 'Daily reconciliation between G8ID and your directories. Detects unauthorised manual changes to AD or LDAP and alerts admins before they cause damage.',
    tags: ['Reconciliation', 'Alerting'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3M3 17V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z" />`,
    title: 'Export for Auditors',
    description: 'Streamed CSV and Excel exports for identity lists and audit logs. Permission-gated and rate-limited. Hand your auditor a spreadsheet, not a login.',
    tags: ['CSV', 'Excel', 'Reports'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />`,
    title: 'Data Sovereignty',
    description: 'All identity data stays within your perimeter. No cloud dependency, no telemetry, no third-party data access. Your data, your infrastructure, your control.',
    tags: ['On-Premise', 'Air-Gap'],
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Time-Bounded Access',
    description: 'Temporary access grants that auto-expire. Privileged access with scheduled revocation. No more "just-for-now" becoming permanent.',
    tags: ['Auto-Expire', 'Least Privilege'],
  },
];
---

<section id="compliance" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Security & Compliance</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Audit-Ready From Day One
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Built for organisations where compliance isn't optional. SOC2, ISO 27001, and PDPA requirements are addressed natively — not bolted on.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {pillars.map((pillar) => (
        <div class="rounded-xl border border-white/5 bg-navy-900/50 p-6 transition-colors hover:border-cyan-400/20">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <Fragment set:html={pillar.icon} />
            </svg>
          </div>
          <h3 class="font-display text-lg font-bold text-white">{pillar.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{pillar.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {pillar.tags.map((tag) => (
              <span class="rounded-full border border-cyan-400/20 bg-cyan-400/5 px-2.5 py-0.5 font-display text-xs text-cyan-400">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
