---
const industries = ['Government', 'Banking', 'Healthcare', 'Defence', 'Telco'];
---

<section id="security" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Security & Compliance</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        On-Premise. Air-Gappable. Audit-Ready.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Your identity data stays inside your perimeter. No SaaS, no cloud dependency, no telemetry. SOC2, ISO 27001, and PDPA compliance built in — not bolted on.
      </p>
    </div>

    <!-- Screenshots -->
    <div class="mt-16 grid gap-6 lg:grid-cols-2">
      <div class="overflow-hidden rounded-xl border border-white/10 shadow-lg">
        <img
          src="/images/audit-log.png"
          alt="G8ID Audit Log — immutable record of every identity operation"
          class="w-full"
          loading="lazy"
        />
        <div class="border-t border-white/5 bg-navy-900/80 px-4 py-2">
          <p class="font-display text-xs text-slate-400">Immutable Audit Trail — every operation recorded with actor and timestamp</p>
        </div>
      </div>
      <div class="overflow-hidden rounded-xl border border-white/10 shadow-lg">
        <img
          src="/images/recertification-detail.png"
          alt="G8ID Recertification Campaign — quarterly access review with reviewer assignments"
          class="w-full"
          loading="lazy"
        />
        <div class="border-t border-white/5 bg-navy-900/80 px-4 py-2">
          <p class="font-display text-xs text-slate-400">Recertification Campaigns — managers certify or revoke access periodically</p>
        </div>
      </div>
    </div>

    <!-- On-premise + Compliance features -->
    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      <div class="flex gap-5 rounded-xl border border-white/5 bg-navy-900/50 p-6 transition-colors hover:border-cyan-400/20">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" />
          </svg>
        </div>
        <div>
          <h3 class="font-display text-lg font-bold text-white">On-Premise Only</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">Runs on your servers, behind your firewall. Linux, Docker, or Kubernetes. Air-gap compatible with zero internet dependency.</p>
        </div>
      </div>

      <div class="flex gap-5 rounded-xl border border-white/5 bg-navy-900/50 p-6 transition-colors hover:border-cyan-400/20">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
          </svg>
        </div>
        <div>
          <h3 class="font-display text-lg font-bold text-white">Immutable Audit Trail</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">Every action logged with actor, before/after state, and approval reference. Cannot be edited or deleted. Export to CSV/Excel for auditors.</p>
        </div>
      </div>

      <div class="flex gap-5 rounded-xl border border-white/5 bg-navy-900/50 p-6 transition-colors hover:border-cyan-400/20">
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
          </svg>
        </div>
        <div>
          <h3 class="font-display text-lg font-bold text-white">Drift Detection</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">Daily reconciliation catches unauthorised manual changes to AD or LDAP. Alerts admins before risk becomes incident.</p>
        </div>
      </div>
    </div>

    <!-- Why not cloud callout -->
    <div class="mx-auto mt-12 max-w-3xl rounded-xl border border-cyan-400/10 bg-cyan-400/[0.02] p-8">
      <h3 class="font-display text-xl font-bold text-white">
        Why not Okta, Azure AD, or JumpCloud?
      </h3>
      <p class="mt-4 leading-relaxed text-slate-400">
        Cloud IAM stores your identity data on their infrastructure. For PDPA-regulated organisations, air-gapped environments, or government networks, that's not an option. G8ID keeps every identity record inside your perimeter. No call-home, no telemetry, no third-party dependency.
      </p>
    </div>

    <!-- Industry tags -->
    <div class="mt-12 text-center">
      <p class="mb-4 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Built for Regulated Industries</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {industries.map((industry) => (
          <span class="rounded-full border border-white/10 bg-white/[0.03] px-5 py-2 font-display text-sm text-slate-300">
            {industry}
          </span>
        ))}
      </div>
    </div>

    <!-- Compliance badges -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      {['SOC2', 'ISO 27001', 'PDPA'].map((badge) => (
        <span class="rounded-full border border-cyan-400/20 bg-cyan-400/5 px-4 py-1.5 font-display text-xs font-bold text-cyan-400">
          {badge}
        </span>
      ))}
    </div>
  </div>
</section>
