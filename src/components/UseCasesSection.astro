---
const useCases = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>`,
    title: 'Government Agencies',
    description: 'Air-gapped deployment with full data sovereignty. PDPA compliance built in. No data leaves the government network — ever.',
    tags: ['Air-Gapped', 'PDPA', 'Data Sovereignty'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'Banking & Finance',
    description: 'Audit-ready trails for every access decision. Privileged access controls with time-bounded elevation and automatic revocation.',
    tags: ['Audit-Ready', 'Audit Trail', 'Privileged Access'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>`,
    title: 'Healthcare',
    description: 'Compliance-ready offboarding ensures no clinician retains access after departure. Role-based access scoped to patient system requirements.',
    tags: ['PDPA', 'RBAC', 'Offboarding'],
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>`,
    title: 'Large Enterprises',
    description: 'Multi-AD forest provisioning across departments and subsidiaries. Centralised control with delegated administration.',
    tags: ['Multi-AD', 'Delegation'],
  },
];
---

<section id="use-cases" class="relative py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Who Deploys G8ID
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Organisations that cannot afford identity sprawl, compliance gaps, or cloud dependency.
      </p>
    </div>

    <div class="mt-16 grid gap-6 sm:grid-cols-2">
      {useCases.map((useCase) => (
        <div class="rounded-xl border border-white/5 bg-navy-900/50 p-8 transition-colors hover:border-cyan-400/20">
          <div class="mb-5 text-cyan-400">
            <Fragment set:html={useCase.icon} />
          </div>
          <h3 class="font-display text-xl font-bold text-white">{useCase.title}</h3>
          <p class="mt-3 leading-relaxed text-slate-400">{useCase.description}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {useCase.tags.map((tag) => (
              <span class="rounded-full border border-cyan-400/20 bg-cyan-400/5 px-3 py-1 font-display text-xs text-cyan-400">
                {tag}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
