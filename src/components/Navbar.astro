---
const navLinks = [
  { label: 'Features', href: '#features' },
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Use Cases', href: '#use-cases' },
  { label: 'Modules', href: '#modules' },
  { label: 'Contact', href: 'mailto:tech@devhub.my?subject=G8ID%20Enquiry' },
];
---

<nav
  class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-navy-950/80 backdrop-blur-xl"
  x-data="{ open: false }"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
    <a href="/" class="font-display text-2xl font-bold tracking-tight text-white">
      G8<span class="text-cyan-400">ID</span>
    </a>

    <div class="hidden items-center gap-8 md:flex">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-slate-300 transition-colors hover:text-cyan-400"
        >
          {link.label}
        </a>
      ))}
      <a
        href="mailto:tech@devhub.my?subject=G8ID%20Demo%20Request"
        class="rounded-lg bg-amber-500 px-5 py-2.5 text-sm font-semibold text-navy-950 transition-colors hover:bg-amber-400"
      >
        Request a Demo
      </a>
    </div>

    <button
      class="text-slate-300 md:hidden"
      @click="open = !open"
      :aria-expanded="open"
      aria-label="Toggle menu"
    >
      <svg x-show="!open" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg x-show="open" x-cloak xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <div
    x-show="open"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150"
    x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2"
    class="border-t border-white/5 bg-navy-950/95 backdrop-blur-xl md:hidden"
  >
    <div class="flex flex-col gap-4 px-6 py-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm font-medium text-slate-300 transition-colors hover:text-cyan-400"
          @click="open = false"
        >
          {link.label}
        </a>
      ))}
      <a
        href="mailto:tech@devhub.my?subject=G8ID%20Demo%20Request"
        class="mt-2 rounded-lg bg-amber-500 px-5 py-2.5 text-center text-sm font-semibold text-navy-950 transition-colors hover:bg-amber-400"
        @click="open = false"
      >
        Request a Demo
      </a>
    </div>
  </div>
</nav>

<style>
  [x-cloak] {
    display: none !important;
  }
</style>
