---
const points = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01" /></svg>`,
    title: 'Deployed Inside Your Network',
    description: 'No SaaS, no cloud dependency. G8ID runs on your servers, behind your firewall, under your control.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" /></svg>`,
    title: 'Air-Gap Compatible',
    description: 'Works in fully isolated environments with zero internet connectivity. No call-home, no telemetry.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>`,
    title: 'Full Data Sovereignty',
    description: 'Identity data never leaves your perimeter. You own every byte. No third-party access, ever.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" /></svg>`,
    title: 'Runs on Your Stack',
    description: 'Linux servers, Docker, or Kubernetes. Fits into your existing infrastructure and deployment pipeline.',
  },
];

const industries = ['Banking', 'Healthcare', 'Government', 'Telco', 'Defence'];
---

<section class="relative py-20 lg:py-28">
  <!-- Subtle border effect -->
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">On-Premise First</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Built for Your Infrastructure. Never Theirs.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        G8ID is designed from the ground up to run inside your network. Your identity data stays where it belongs — with you.
      </p>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-2">
      {points.map((point) => (
        <div class="flex gap-5 rounded-xl border border-cyan-400/10 bg-cyan-400/[0.02] p-6">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-cyan-400/10 text-cyan-400">
            <Fragment set:html={point.icon} />
          </div>
          <div>
            <h3 class="font-display text-lg font-bold text-white">{point.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{point.description}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <p class="mb-4 font-display text-sm font-bold uppercase tracking-widest text-slate-500">Built for Regulated Industries</p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        {industries.map((industry) => (
          <span class="rounded-full border border-white/10 bg-white/[0.03] px-5 py-2 font-display text-sm text-slate-300">
            {industry}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
