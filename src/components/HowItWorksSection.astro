---
const steps = [
  {
    number: '01',
    title: 'Request Submitted',
    description: 'HR submits a new joiner request, or an employee requests access through the self-service portal.',
  },
  {
    number: '02',
    title: 'Manager Approval',
    description: 'Line manager receives a notification and approves the request based on role and department policy.',
  },
  {
    number: '03',
    title: 'Security Review',
    description: 'IT security reviews and approves privileged access requests. Standard access flows through automatically.',
  },
  {
    number: '04',
    title: 'Automated Provisioning',
    description: 'G8ID provisions the identity to Active Directory and LDAP. SSO providers like Keycloak pick up changes automatically via federation.',
  },
  {
    number: '05',
    title: 'Audit Recorded',
    description: 'Every step, actor, decision, and timestamp is recorded in the immutable audit log. Compliance-ready.',
  },
  {
    number: '06',
    title: 'Account Activated',
    description: 'Users receive an activation link via email. They set their own password and activate their account — no IT intervention needed. Activation can also be triggered programmatically from your existing onboarding application via the G8ID API. Time-bounded permissions auto-expire when the window closes.',
  },
];
---

<section id="how-it-works" class="relative py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <h2 class="font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        From Request to Access in Minutes
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        Every identity operation follows the same controlled path. No shortcuts, no exceptions.
      </p>
    </div>

    <div class="relative mt-16">
      <!-- Vertical line connector (desktop) -->
      <div class="absolute left-[2.35rem] top-0 bottom-0 hidden w-px bg-gradient-to-b from-cyan-400/40 via-cyan-400/20 to-transparent lg:block"></div>

      <div class="space-y-6 lg:space-y-0">
        {steps.map((step, i) => (
          <div class="relative flex gap-6 lg:gap-10 lg:py-6">
            <!-- Step number -->
            <div class="relative z-10 flex h-[3rem] w-[3rem] shrink-0 items-center justify-center rounded-full border border-cyan-400/30 bg-navy-950 font-display text-sm font-bold text-cyan-400 lg:h-[3.2rem] lg:w-[3.2rem]">
              {step.number}
            </div>

            <!-- Content -->
            <div class="rounded-xl border border-white/5 bg-navy-900/30 p-6 flex-1">
              <h3 class="font-display text-lg font-bold text-white">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-400">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
