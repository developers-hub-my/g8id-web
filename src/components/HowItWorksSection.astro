---
const steps = [
  {
    number: '01',
    title: 'Connect Your Directories',
    description: 'Point G8ID at your Active Directory or LDAP servers. The guided setup wizard supports Corporate AD, OpenLDAP, and FreeIPA out of the box.',
  },
  {
    number: '02',
    title: 'Define Policies & Roles',
    description: 'Configure approval levels, map roles to directory groups, and set up recertification schedules. G8ID enforces your rules automatically.',
  },
  {
    number: '03',
    title: 'Manage Through the Gate',
    description: 'Every identity operation — provision, transfer, suspend, offboard — flows through G8ID\'s approval pipeline. No more direct AD edits.',
  },
  {
    number: '04',
    title: 'Audit Everything',
    description: 'Every action is recorded in an immutable log. Export evidence for SOC2, ISO 27001, and PDPA reviews. Drift detection catches unauthorised changes.',
  },
];
---

<section id="how-it-works" class="relative py-20 lg:py-28">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-cyan-400/20 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-6">
    <div class="text-center">
      <span class="font-display text-sm font-bold uppercase tracking-widest text-cyan-400">Getting Started</span>
      <h2 class="mt-4 font-display text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Up and Running in Minutes
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-400">
        A guided setup wizard walks you through connecting your directories. No migration, no downtime.
      </p>
    </div>

    <!-- Setup wizard screenshots -->
    <div class="mt-16 grid gap-6 lg:grid-cols-2">
      <div class="overflow-hidden rounded-xl border border-white/10 shadow-lg">
        <img
          src="/images/setup-wizard.png"
          alt="G8ID Setup Wizard — guided 7-step setup with quick-start templates for Active Directory, OpenLDAP, and FreeIPA"
          class="w-full"
          loading="lazy"
        />
      </div>
      <div class="overflow-hidden rounded-xl border border-white/10 shadow-lg">
        <img
          src="/images/setup-connector.png"
          alt="G8ID Connector Configuration — directory server connection details with SSL/TLS options"
          class="w-full"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Steps -->
    <div class="mt-16 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {steps.map((step) => (
        <div class="rounded-xl border border-white/5 bg-navy-900/50 p-6 transition-colors hover:border-cyan-400/20">
          <span class="font-display text-3xl font-bold text-cyan-400/20">{step.number}</span>
          <h3 class="mt-3 font-display text-lg font-bold text-white">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-400">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
