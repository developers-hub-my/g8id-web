---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import ProblemSection from '../components/ProblemSection.astro';
import SolutionSection from '../components/SolutionSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import LifecycleSection from '../components/LifecycleSection.astro';
import OnPremiseSection from '../components/OnPremiseSection.astro';
import WhyOnPremiseSection from '../components/WhyOnPremiseSection.astro';
import ModulesSection from '../components/ModulesSection.astro';
import OffboardingSection from '../components/OffboardingSection.astro';
import IntegrationsSection from '../components/IntegrationsSection.astro';
import UseCasesSection from '../components/UseCasesSection.astro';
import HowItWorksSection from '../components/HowItWorksSection.astro';
import ComplianceSection from '../components/ComplianceSection.astro';
import DocsSection from '../components/DocsSection.astro';
import CtaSection from '../components/CtaSection.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Navbar />
  <main>
    <Hero />
    <ProblemSection />
    <SolutionSection />
    <FeaturesSection />
    <LifecycleSection />
    <OnPremiseSection />
    <WhyOnPremiseSection />
    <ModulesSection />
    <OffboardingSection />
    <IntegrationsSection />
    <UseCasesSection />
    <HowItWorksSection />
    <ComplianceSection />
    <DocsSection />
    <CtaSection />
  </main>
  <Footer />
</BaseLayout>
